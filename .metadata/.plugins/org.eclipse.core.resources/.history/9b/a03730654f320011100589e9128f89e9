package com.klu.scholarship.service;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import com.klu.scholarship.entity.Application;
import com.klu.scholarship.entity.User;
import com.klu.scholarship.entity.Scholarship;
import com.klu.scholarship.repository.ApplicationRepository;
import com.klu.scholarship.repository.UserRepository;
import com.klu.scholarship.repository.ScholarshipRepository;

@Service
public class ApplicationService {

    @Autowired
    private ApplicationRepository appRepo;

    @Autowired
    private UserRepository userRepo;

    @Autowired
    private ScholarshipRepository schRepo;

    @Autowired
    private EmailService emailService;

    @Autowired
    private NotificationService notificationService;

    // ✅ APPLY FOR SCHOLARSHIP
    public Application apply(Long userId, Long scholarshipId) {

        Application app = new Application();

        // 🔹 Fetch User safely
        User user = userRepo.findById(userId)
                .orElseThrow(() -> new RuntimeException("User not found"));

        // 🔹 Fetch Scholarship safely
        Scholarship scholarship = schRepo.findById(scholarshipId)
                .orElseThrow(() -> new RuntimeException("Scholarship not found"));

        // 🔹 Set values
        app.setUser(user);
        app.setScholarship(scholarship);
        app.setStatus("PENDING");

        // 🔹 Save application
        Application saved = appRepo.save(app);

        // 🔹 Send Email
        emailService.sendMail(
                user.getEmail(),
                "Application Submitted",
                "You successfully applied for the scholarship!"
        );

        // 🔹 Send Notification
        notificationService.notifyUser(
                userId,
                "Application submitted successfully"
        );

        return saved;
    }

    // ✅ GET APPLICATIONS BY USER
    public List<Application> getByUser(Long userId) {
        return appRepo.findByUserId(userId);
    }
}